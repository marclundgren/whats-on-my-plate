NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:password@localhost:5432/whats_on_my_plate
CLIENT_URL=http://localhost:5173

# --- Auth (leave SELF_HOSTED=true for local use; set to false for hosted deployment) ---
SELF_HOSTED=true

# Required when SELF_HOSTED=false:
# JWT_SECRET=<generate with: openssl rand -hex 64>
# SESSION_SECRET=<generate with: openssl rand -hex 32>
# FRONTEND_URL=https://<username>.github.io/whats-on-my-plate

# GitHub OAuth app (github.com → Settings → Developer settings → OAuth Apps)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=https://<railway-url>/api/auth/github/callback

# Google OAuth (console.cloud.google.com → APIs & Services → Credentials)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://<railway-url>/api/auth/google/callback
